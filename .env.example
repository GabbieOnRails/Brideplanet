# Bridexx Planet - Environment Variables

# App
NODE_ENV=production
PORT=3000
APP_URL=https://bridexxplanet.com

# Resend (Email Service)
RESEND_API_KEY=re_your_api_key

# Paystack (Payments)
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key
PAYSTACK_SECRET_KEY=sk_live_your_secret_key

# Firebase (Database & Auth - Client Side)
# These are usually handled in firebase-applet-config.json
# but you can add them here if you use process.env in your build
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
